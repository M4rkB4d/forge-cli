{
  "name": "bff-springboot",
  "displayName": "Spring Boot BFF",
  "category": "bff",
  "version": "1.0.0",
  "runtime": "java",
  "variables": {
    "groupId": {
      "type": "text",
      "prompt": "Group ID",
      "default": "com.company",
      "placeholder": "com.company"
    },
    "javaVersion": {
      "type": "select",
      "prompt": "Java version",
      "choices": ["25", "21", "17"],
      "default": "25"
    },
    "springBootVersion": {
      "type": "text",
      "prompt": "Spring Boot version",
      "default": "4.0.5"
    }
  },
  "prompts": [
    {
      "name": "authPattern",
      "type": "select",
      "message": "Authentication pattern",
      "choices": ["OAuth2 + Azure AD", "JWT", "None"]
    }
  ],
  "compatibleLayers": ["azure-infra", "ci-pipeline"],
  "postCreate": []
}
