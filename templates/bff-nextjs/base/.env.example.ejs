# ─── Application ───────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Backend Services ─────────────────────────────────────
SAMPLE_SERVICE_URL=http://localhost:8080
<% if (authPattern === 'Azure AD Token Validation') { %>
# ─── Azure AD ─────────────────────────────────────────────
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_AUDIENCE=
<% } else if (authPattern === 'JWT') { %>
# ─── JWT ──────────────────────────────────────────────────
JWT_ISSUER=
JWT_AUDIENCE=
JWT_SECRET=
<% } %>
# ─── Observability (optional) ─────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
