export interface TokenPayload {
  sub: string;
  roles: string[];
  name: string;
  email: string;
}

<% if (authPattern === 'Azure AD Token Validation') { %>
import * as jose from 'jose';
import { env } from '@/lib/config/env';

let jwks: ReturnType<typeof jose.createRemoteJWKSet> | null = null;

function getJwks() {
  if (!jwks) {
    const jwksUri = `https://login.microsoftonline.com/${env.AZURE_AD_TENANT_ID}/discovery/v2.0/keys`;
    jwks = jose.createRemoteJWKSet(new URL(jwksUri));
  }
  return jwks;
}

/**
 * Validate an Azure AD JWT and return the decoded payload.
 */
export async function validateToken(token: string): Promise<TokenPayload> {
  const issuer = `https://login.microsoftonline.com/${env.AZURE_AD_TENANT_ID}/v2.0`;

  const { payload } = await jose.jwtVerify(token, getJwks(), {
    audience: env.AZURE_AD_AUDIENCE,
    issuer,
    algorithms: ['RS256'],
  });

  return {
    sub: payload.sub ?? '',
    roles: (payload.roles as string[]) ?? [],
    name: (payload.name as string) ?? '',
    email: (payload.preferred_username as string) ?? (payload.email as string) ?? '',
  };
}
<% } else if (authPattern === 'JWT') { %>
import * as jose from 'jose';
import { env } from '@/lib/config/env';

let secret: Uint8Array | null = null;

function getSecret(): Uint8Array {
  if (!secret) {
    secret = new TextEncoder().encode(env.JWT_SECRET);
  }
  return secret;
}

/**
 * Validate a JWT signed with a shared secret and return the decoded payload.
 */
export async function validateToken(token: string): Promise<TokenPayload> {
  const { payload } = await jose.jwtVerify(token, getSecret(), {
    algorithms: ['HS256'],
  });

  return {
    sub: payload.sub ?? '',
    roles: (payload.roles as string[]) ?? [],
    name: (payload.name as string) ?? '',
    email: (payload.email as string) ?? '',
  };
}
<% } else { %>
/**
 * No-op validator — authentication is disabled.
 */
export async function validateToken(_token: string): Promise<TokenPayload> {
  return {
    sub: 'anonymous',
    roles: [],
    name: 'Anonymous',
    email: '',
  };
}
<% } %>
