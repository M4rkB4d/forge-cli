import { NextRequest } from 'next/server';
import { handleApiError } from '@/lib/errors/error-response';
import { getCorrelationId } from '@/lib/logging/correlation';
import { logger } from '@/lib/logging/logger';

/**
 * GET /api/example
 *
 * Minimal reference route showing the BFF request lifecycle:
 *   correlationId → child logger → try/catch → handleApiError
 *
 * For a complete CRUD example with client calls, validation, and mapping,
 * see the /api/sample routes.
 */
export async function GET(request: NextRequest) {
  const correlationId = getCorrelationId(request);
  const log = logger.child({ correlationId, route: '/api/example' });

  try {
    log.info('Example health check');

    return Response.json({
      status: 'ok',
      service: '<%= projectName %>',
      correlationId,
    });
  } catch (error) {
    return handleApiError(error, correlationId, log);
  }
}
