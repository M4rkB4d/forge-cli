{
  "name": "backend-springboot",
  "displayName": "Spring Boot Backend Service",
  "category": "backend",
  "version": "1.0.0",
  "runtime": "java",
  "variables": {
    "groupId": {
      "type": "text",
      "prompt": "Group ID",
      "default": "com.company",
      "placeholder": "com.company"
    }
  },
  "prompts": [
    {
      "name": "authPattern",
      "type": "select",
      "message": "Authentication pattern",
      "choices": ["OAuth2 + Azure AD", "JWT", "None"]
    },
    {
      "name": "messaging",
      "type": "select",
      "message": "Message broker",
      "choices": ["Kafka", "Azure Service Bus", "None"]
    }
  ],
  "compatibleLayers": ["azure-sql", "azure-infra", "ci-pipeline"],
  "postCreate": []
}
