spring:
  datasource:
    url: jdbc:sqlserver://localhost:1433;databaseName=<%= projectName %>;encrypt=false
    username: sa
    password: ${DB_PASSWORD:LocalDev123!}
  flyway:
    out-of-order: true
<%_ if (authPattern === 'OAuth2 + Azure AD') { -%>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: https://login.microsoftonline.com/${AZURE_TENANT_ID:your-tenant-id}/v2.0
          audiences: ${AZURE_CLIENT_ID:your-client-id}
<%_ } else if (authPattern === 'JWT') { -%>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: ${JWT_ISSUER_URI:https://localhost:8443/realms/local}
<%_ } -%>
<%_ if (messaging === 'Kafka') { -%>
  kafka:
    bootstrap-servers: localhost:9092
<%_ } -%>

logging:
  level:
    <%= groupId %>: DEBUG
    org.hibernate.SQL: DEBUG
