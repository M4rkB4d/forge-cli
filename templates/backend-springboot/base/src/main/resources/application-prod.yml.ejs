spring:
  datasource:
    url: ${DATABASE_URL}
    username: ${DATABASE_USERNAME}
    password: ${DATABASE_PASSWORD}
    hikari:
      maximum-pool-size: ${HIKARI_MAX_POOL:10}
      minimum-idle: ${HIKARI_MIN_IDLE:5}
      connection-timeout: 5000
      idle-timeout: 300000
      max-lifetime: 600000
      leak-detection-threshold: 60000
      data-source-properties:
        lockTimeout: 3000
  jpa:
    properties:
      hibernate:
        jdbc:
          batch_size: 25
        order_inserts: true
        order_updates: true
  flyway:
    clean-disabled: true
  lifecycle:
    timeout-per-shutdown-phase: 30s
<%_ if (messaging === 'Kafka') { -%>
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS}
<%_ } -%>

management:
  tracing:
    sampling:
      probability: 0.1

logging:
  level:
    root: WARN
    <%= groupId %>: INFO
