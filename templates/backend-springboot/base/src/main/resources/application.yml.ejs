server:
  port: 8080

spring:
  application:
    name: <%= projectName %>
<% if (authPattern === 'OAuth2 + Azure AD') { %>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: ${AZURE_AD_ISSUER_URI}
<% } %>

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: when-authorized

logging:
  level:
    root: INFO
    <%= packageName %>: DEBUG
