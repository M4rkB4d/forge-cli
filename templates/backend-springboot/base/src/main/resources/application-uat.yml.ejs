spring:
  datasource:
    url: ${DATABASE_URL}
    username: ${DATABASE_USERNAME}
    password: ${DATABASE_PASSWORD}
  flyway:
    clean-disabled: true
<%_ if (messaging === 'Kafka') { -%>
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS}
<%_ } -%>

management:
  tracing:
    sampling:
      probability: 0.5

logging:
  level:
    root: WARN
    <%= groupId %>: INFO
