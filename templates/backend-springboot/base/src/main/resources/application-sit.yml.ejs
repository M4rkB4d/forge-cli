spring:
  datasource:
    url: ${DATABASE_URL}
    username: ${DATABASE_USERNAME}
    password: ${DATABASE_PASSWORD}
  flyway:
    clean-disabled: true
<% if (messaging === 'Kafka') { %>
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS}
<% } %>

logging:
  level:
    root: WARN
    <%= groupId %>: INFO
