server:
  port: 8080

spring:
  application:
    name: <%= projectName %>
  datasource:
    url: jdbc:h2:mem:<%= projectName %>;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
    driver-class-name: org.h2.Driver
    username: sa
    password:
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: true
  flyway:
    enabled: false
  h2:
    console:
      enabled: true
      path: /h2-console

logging:
  level:
    root: INFO
    <%= packageName %>: DEBUG
    org.springframework.web: DEBUG
    org.hibernate.SQL: DEBUG
