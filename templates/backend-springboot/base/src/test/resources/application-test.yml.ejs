# Test profile configuration
spring:
  main:
    allow-bean-definition-overriding: true
  application:
    name: <%= projectName %>-test
  datasource:
    url: jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
    driver-class-name: org.h2.Driver
    username: sa
    password:
  jpa:
    database-platform: org.hibernate.dialect.H2Dialect
    hibernate:
      ddl-auto: create-drop
  flyway:
    enabled: false
<% if (messaging === 'Azure Service Bus') { %>
  jms:
    servicebus:
      connection-string: Endpoint=sb://test.servicebus.windows.net/;SharedAccessKeyName=test;SharedAccessKey=dGVzdA==
      pricing-tier: standard
<% } %>
<% if (authPattern === 'OAuth2 + Azure AD') { %>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: https://login.microsoftonline.com/test-tenant-id/v2.0
<% } %>

logging:
  level:
    root: WARN
    <%= packageName %>: DEBUG
