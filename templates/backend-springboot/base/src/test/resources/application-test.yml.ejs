spring:
  application:
    name: <%= projectName %>-test
  flyway:
    enabled: true
<%_ if (messaging === 'Azure Service Bus') { -%>
  cloud:
    azure:
      servicebus:
        namespace: test-namespace
        entity-type: queue
<%_ } -%>
<%_ if (messaging === 'Kafka') { -%>
  kafka:
    bootstrap-servers: ${spring.embedded.kafka.brokers:localhost:9092}
<%_ } -%>
<%_ if (authPattern === 'OAuth2 + Azure AD') { -%>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: https://login.microsoftonline.com/test-tenant-id/v2.0
<%_ } else if (authPattern === 'JWT') { -%>
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: https://test-issuer.example.com
<%_ } -%>

management:
  endpoint:
    health:
      group:
        readiness:
          include: db
        liveness:
          include: livenessState

logging:
  level:
    root: WARN
    <%= groupId %>: DEBUG
