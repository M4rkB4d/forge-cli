const BFF_URL = process.env.BFF_URL || 'http://localhost:3000';

export async function fetchFromBFF<T>(path: string, init?: RequestInit): Promise<T> {
  const res = await fetch(`${BFF_URL}${path}`, {
    ...init,
    headers: {
      'Content-Type': 'application/json',
      ...init?.headers,
    },
  });

  if (!res.ok) {
    throw new Error(`BFF error: ${res.status} ${res.statusText}`);
  }

  return res.json();
}
